{
  "name": "common-ground",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @common-ground/web dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test && go test ./runner/...",
    "test:e2e": "pnpm --filter @common-ground/web test:e2e"
  }
}
